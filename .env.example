# Configuracao local opcional para a esteira Valley.
# DATABASE_URL aponta para PostgreSQL local, externo ou container Compose.
DATABASE_URL=postgresql://valley:valley_dev_password@localhost:55432/valley

# MONGODB_URI aponta para MongoDB local, externo ou container Compose.
MONGODB_URI=mongodb://localhost:57017/valley

# VALLEY_AUTO_APPLY controla se a automacao pode aplicar migrations sem flag explicita.
VALLEY_AUTO_APPLY=false

# VALLEY_NGROK_AUTHTOKEN injeta o token de autenticao do ngrok via .env local.
VALLEY_NGROK_AUTHTOKEN=

# VALLEY_NGROK_ADMIN_DOMAIN fixa o dominio reservado para o painel admin em release.
VALLEY_NGROK_ADMIN_DOMAIN=

# Stitch MCP: usado pelo fluxo persistente de design front-end.
# Gere a chave em https://stitch.withgoogle.com/settings e mantenha apenas no .env local.
STITCH_API_KEY=

# GitHub Actions runner self-hosted: token de registro local e efêmero.
# Nunca versionar. Gere um novo token na página do runner antes de configurar.
GITHUB_RUNNER_TOKEN=

# Termius/SSH externo: segredos reais ficam apenas no .env local.
CLOUDFLARED_TOKEN=
TAILSCALE_AUTHKEY=
TAILSCALE_API_KEY=
ZEROTIER_NETWORK_ID=
VALLEY_TAILSCALE_HOSTNAME=valley-codex
VALLEY_TAILSCALE_SSH=true
TS_AUTHKEY=
VALLEY_TAILSCALE_DOCKER_HOSTNAME=valley-mcp-docker
VALLEY_TAILSCALE_DOCKER_EXTRA_ARGS=--accept-routes
VALLEY_TAILSCALE_USERSPACE=false
VALLEY_TAILSCALE_WSL_HOSTNAME=valley-wsl2
VALLEY_TAILSCALE_WSL_DISTRO=Ubuntu
VALLEY_TAILSCALE_WSL_USER=eretazan
VALLEY_TERMIUS_SSH_HOST=
VALLEY_TERMIUS_SSH_USER=
VALLEY_TERMIUS_SSH_PORT=22
VALLEY_TERMIUS_ROUTE=tailscale
VALLEY_TERMIUS_CLOUDFLARE_HOST=

# Telegram bridge seguro. Tokens reais ficam apenas no .env local.
VALLEY_TELEGRAM_TOKEN=
VALLEY_TELEGRAM_CHAT_ID=

# WhatsApp Web local. Login manual pelo navegador; nao usa API oficial.
VALLEY_WHATSAPP_MODE=web
VALLEY_WHATSAPP_WEB_TO=
VALLEY_WHATSAPP_WEB_PROFILE_DIR=tmp/runtime/whatsapp-web-profile
VALLEY_WHATSAPP_WEB_BROWSER=msedge
VALLEY_WHATSAPP_WEB_HEADLESS=false
VALLEY_MERCADOPAGO_ACCESS_TOKEN=
VALLEY_MERCADOPAGO_PUBLIC_KEY=
VALLEY_MERCADOPAGO_WEBHOOK_SECRET=

# Credenciais locais de fornecedores/fontes de preco.
# Nao versionar valores reais; use apenas .env local, vault ou secret manager.
# O bootstrap aceita credencial compartilhada e sobrescrita por provedor.
VALLEY_SUPPLIER_SHARED_USER=
VALLEY_SUPPLIER_SHARED_PASSWORD=
AMAZON_USER=
AMAZON_PASSWORD=
ALIBABA_USER=
ALIBABA_PASSWORD=
SHOPEE_USER=
SHOPEE_PASSWORD=
# Alias tolerado para erro comum de grafia; prefira SHOPEE_*.
SHOPPE_USER=
SHOPPE_PASSWORD=

# Tokens/API oficiais por provedor. Preferir estes valores em producao.
CJDROPSHIPPING_ACCESS_TOKEN=
CJDROPSHIPPING_REFRESH_TOKEN=
CJDROPSHIPPING_OPEN_ID=
ALIEXPRESS_CLIENT_ID=
ALIEXPRESS_CLIENT_SECRET=
ALIEXPRESS_ACCESS_TOKEN=
ALIEXPRESS_REFRESH_TOKEN=
ALIBABA_CLIENT_ID=
ALIBABA_CLIENT_SECRET=
ALIBABA_ACCESS_TOKEN=
ALIBABA_REFRESH_TOKEN=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_ACCESS_TOKEN=
AMAZON_REFRESH_TOKEN=
AMAZON_SELLER_ID=
SHOPEE_CLIENT_ID=
SHOPEE_CLIENT_SECRET=
SHOPEE_ACCESS_TOKEN=
SHOPEE_REFRESH_TOKEN=
SHOPEE_SELLER_ID=

# Legacy/API oficial desativada por padrao.
VALLEY_WHATSAPP_API_URL=
VALLEY_WHATSAPP_TOKEN=
VALLEY_WHATSAPP_TO=
VALLEY_BRIDGE_AUTO_APPROVAL=safe_only
