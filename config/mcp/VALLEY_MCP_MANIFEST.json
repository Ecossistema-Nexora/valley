{
  "version": "v47",
  "purpose": "release-integrations",
  "workspace_declarations": [
    ".mcp.json",
    ".vscode/mcp.json"
  ],
  "network_overlay": {
    "provider": "tailscale",
    "docker_compose_profile": "tailscale",
    "mcp_compose_profile": "mcp",
    "docker_service": "tailscale",
    "container_name": "valley-tailscale-mcp",
    "wsl2_bootstrap": "scripts/start_tailscale_wsl.ps1",
    "wsl2_keepalive": "scripts/start_tailscale_wsl_keepalive.ps1",
    "termius_status": "scripts/termius_tailscale_status.ps1",
    "runbook": "config/termius/TAILSCALE_DOCKER_WSL.md",
    "secrets": [
      "TAILSCALE_AUTHKEY",
      "TS_AUTHKEY"
    ],
    "secret_policy": "local_env_only"
  },
  "servers": {
    "github": {
      "mode": "platform-managed",
      "platform_name": "GitHub",
      "auth": "platform_token",
      "reason": "GitHub tooling ja e fornecido pelo host do agente e permanece fora do workspace para evitar autenticacao duplicada.",
      "repository_scope": {
        "policy": "single_repository_only",
        "owner": "Ecossistema-Nexora",
        "repo": "valley",
        "url": "https://github.com/Ecossistema-Nexora/valley",
        "remote_name": "origin"
      }
    },
    "docker": {
      "mode": "platform-managed",
      "platform_name": "MCP_DOCKER",
      "auth": "platform_session",
      "reason": "A automacao de containers deste projeto usa o conector provido pela plataforma do agente; nao ha endpoint repo-local para declarar."
    },
    "figma": {
      "mode": "workspace-declared",
      "transport": "http",
      "url": "https://mcp.figma.com/mcp",
      "auth": "oauth",
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json"
      ]
    },
    "linear": {
      "mode": "workspace-declared",
      "transport": "http",
      "url": "https://mcp.linear.app/mcp",
      "auth": "oauth",
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json"
      ],
      "notes": [
        "O endpoint oficial atual usa /mcp.",
        "O transporte /sse foi descontinuado."
      ]
    },
    "cloudflare-api": {
      "mode": "workspace-declared",
      "transport": "http",
      "url": "https://mcp.cloudflare.com/mcp",
      "auth": "oauth",
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json"
      ]
    }
  }
}
