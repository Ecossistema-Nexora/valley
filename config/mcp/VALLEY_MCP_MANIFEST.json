{
  "version": "v48",
  "purpose": "release-integrations",
  "mandatory_policy": {
    "status": "required",
    "required_capabilities": [
      "MCP_DOCKER",
      "context7",
      "figma",
      "linear",
      "playwright"
    ],
    "validation_script": "scripts/check_valley_mcp_config.ps1",
    "secret_policy": "no_secrets_in_repo",
    "notes": [
      "MCP_DOCKER is platform-managed and must not be duplicated as a workspace endpoint.",
      "context7, figma, linear and playwright must remain declared in repo-local MCP configuration.",
      "OAuth tokens and API keys stay in the local MCP client, environment or secret manager."
    ]
  },
  "workspace_declarations": [
    ".mcp.json",
    ".vscode/mcp.json",
    ".codex/config.toml"
  ],
  "network_overlay": {
    "provider": "tailscale",
    "docker_compose_profile": "tailscale",
    "mcp_compose_profile": "mcp",
    "docker_service": "tailscale",
    "container_name": "valley-tailscale-mcp",
    "wsl2_bootstrap": "scripts/start_tailscale_wsl.ps1",
    "wsl2_keepalive": "scripts/start_tailscale_wsl_keepalive.ps1",
    "termius_status": "scripts/termius_tailscale_status.ps1",
    "runbook": "config/termius/TAILSCALE_DOCKER_WSL.md",
    "secrets": [
      "TAILSCALE_AUTHKEY",
      "TS_AUTHKEY"
    ],
    "secret_policy": "local_env_only"
  },
  "servers": {
    "github": {
      "mode": "platform-managed",
      "platform_name": "GitHub",
      "auth": "platform_token",
      "reason": "GitHub tooling ja e fornecido pelo host do agente e permanece fora do workspace para evitar autenticacao duplicada.",
      "repository_scope": {
        "policy": "single_repository_only",
        "owner": "Ecossistema-Nexora",
        "repo": "valley",
        "url": "https://github.com/Ecossistema-Nexora/valley",
        "remote_name": "origin"
      }
    },
    "docker": {
      "mode": "platform-managed",
      "platform_name": "MCP_DOCKER",
      "auth": "platform_session",
      "mandatory": true,
      "reason": "A automacao de containers deste projeto usa o conector provido pela plataforma do agente; nao ha endpoint repo-local para declarar."
    },
    "figma": {
      "mode": "workspace-declared",
      "transport": "http",
      "url": "https://mcp.figma.com/mcp",
      "auth": "oauth",
      "mandatory": true,
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json",
        ".codex/config.toml"
      ]
    },
    "context7": {
      "mode": "workspace-declared",
      "transport": "http",
      "url": "https://mcp.context7.com/mcp/oauth",
      "fallback_url": "https://mcp.context7.com/mcp",
      "auth": "oauth_or_local_api_key",
      "mandatory": true,
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json",
        ".codex/config.toml"
      ],
      "secret_policy": "CONTEXT7_API_KEY local only when using the non-OAuth endpoint",
      "notes": [
        "Use /mcp/oauth for clients that support remote OAuth.",
        "Use /mcp with CONTEXT7_API_KEY only in private local client configuration when OAuth is unavailable."
      ]
    },
    "stitch": {
      "mode": "workspace-declared",
      "transport": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "auth": "api_key_or_oauth",
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json"
      ],
      "secret_policy": "local_env_or_client_prompt_only",
      "frontend_policy": "primary_ai_layout_generator"
    },
    "linear": {
      "mode": "workspace-declared",
      "transport": "http",
      "url": "https://mcp.linear.app/mcp",
      "auth": "oauth",
      "mandatory": true,
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json",
        ".codex/config.toml"
      ],
      "notes": [
        "O endpoint oficial atual usa /mcp.",
        "O transporte /sse foi descontinuado."
      ]
    },
    "playwright": {
      "mode": "workspace-declared",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--user-data-dir=tmp/runtime/playwright-mcp-profile",
        "--output-dir=tmp/runtime/playwright-mcp"
      ],
      "auth": "none",
      "mandatory": true,
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json",
        ".codex/config.toml"
      ],
      "state_policy": "persistent_local_profile_under_ignored_tmp_runtime",
      "notes": [
        "Browser automation and visual validation must use Playwright MCP when a real browser check is needed.",
        "Do not commit browser profiles, screenshots with secrets, storage state or captured auth artifacts."
      ]
    },
    "cloudflare-api": {
      "mode": "workspace-declared",
      "transport": "http",
      "url": "https://mcp.cloudflare.com/mcp",
      "auth": "oauth",
      "declared_in": [
        ".mcp.json",
        ".vscode/mcp.json"
      ]
    }
  }
}
