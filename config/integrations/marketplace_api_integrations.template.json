{
  "version": "1.0.0",
  "owner": "VALLEY_STOCK_MARKETPLACE",
  "purpose": "Template sem segredos para configurar integracoes de catalogo, pedidos, precos, estoque e repasse financeiro com marketplaces externos.",
  "security_rules": [
    "Nunca armazenar client_secret, access_token ou refresh_token em texto puro neste arquivo.",
    "Usar apenas referencias de segredo em vault, secret manager ou variaveis protegidas.",
    "Ativar ambiente production somente depois de validar OAuth, webhooks, limites de taxa, margem minima e conciliação financeira.",
    "Toda venda importada deve passar por PAY, PLUG, DOCS e regra de margem minima antes de ser publicada como oferta Valley."
  ],
  "defaults": {
    "environment": "sandbox",
    "authMode": "oauth2",
    "scopes": "catalog,orders,pricing,inventory,settlement",
    "syncCadenceMinutes": 30,
    "cacheTtlMinutes": 20,
    "marginFloorPct": 12,
    "stockModuleEnabled": true,
    "sandboxEnabled": true,
    "productionEnabled": true,
    "importCatalog": true,
    "importCategories": true,
    "syncOrders": true,
    "syncInventory": true,
    "syncPricing": true,
    "publishApprovedOnly": true,
    "requireRetailAdvantage": true,
    "requireLiquidityCheck": true,
    "allowScrapingFallback": false,
    "blockExternalAiLookup": true
  },
  "providers": [
    {
      "key": "mercado_livre",
      "label": "Mercado Livre",
      "providerRole": "marketplace_price",
      "siteCode": "MLB",
      "baseUrl": "https://api.mercadolibre.com",
      "clientId": "",
      "secretRef": "vault/marketplaces/mercado_livre/client-secret",
      "accessTokenRef": "vault/marketplaces/mercado_livre/access-token",
      "refreshTokenRef": "vault/marketplaces/mercado_livre/refresh-token",
      "sellerId": "",
      "webhookUrl": "/webhooks/marketplaces/mercado_livre",
      "webhookSecretRef": "vault/marketplaces/mercado_livre/webhook-secret"
    },
    {
