{
  "profile_name": "terminal_control",
  "shell": "powershell",
  "login": false,
  "command_policy": {
    "prefer_non_interactive": true,
    "prefer_absolute_paths": true,
    "prefer_structured_scripts": true,
    "report_blocked_state_honestly": true,
    "avoid_shell_chains_when_noisy": true
  },
  "release_runtime": {
    "database": "powershell -ExecutionPolicy Bypass -File scripts/run_valley_compose_builder.ps1",
    "report": "python scripts/valley_db_orchestrator.py report",
    "module_sync": "python scripts/valley_module_automation.py sync"
  }
}
