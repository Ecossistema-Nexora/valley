# GitHub repository binding
GITHUB_REPOSITORY_OWNER=Ecossistema-Nexora
GITHUB_REPOSITORY_NAME=valley
GITHUB_REPOSITORY_URL=https://github.com/Ecossistema-Nexora/valley
GIT_REMOTE_NAME=origin
GIT_REMOTE_FETCH_URL=https://github.com/Ecossistema-Nexora/valley.git
GIT_REMOTE_PUSH_URL=https://github.com/Ecossistema-Nexora/valley.git

# Public release runtime
# ngrok esta desabilitado no fluxo de release Valley.
# A rota primaria de release deve ser Cloudflare; nao defina variaveis ngrok aqui.
VALLEY_NGROK_RELEASE_DISABLED=true
