{
  "version": "v47",
  "workspace_extensions": [
    "Google.geminicodeassist",
    "ms-python.python",
    "ms-python.vscode-pylance",
    "ms-azuretools.vscode-docker",
    "ms-kubernetes-tools.vscode-kubernetes-tools",
    "mongodb.mongodb-vscode",
    "redhat.vscode-yaml",
    "esbenp.prettier-vscode",
    "dbaeumer.vscode-eslint",
    "ms-vscode-remote.remote-containers"
  ],
  "host_tools": [
    {
      "name": "code",
      "type": "command",
      "required": true
    },
    {
      "name": "python",
      "type": "command",
      "required": true
    },
    {
      "name": "node",
      "type": "command",
      "required": true
    },
    {
      "name": "docker",
      "type": "command",
      "required": true
    },
    {
      "name": "MongoDB Shell",
      "type": "winget",
      "id": "MongoDB.Shell",
      "required": false
    },
    {
      "name": "PostgreSQL 16",
      "type": "winget",
      "id": "PostgreSQL.PostgreSQL.16",
      "required": false
    }
  ],
  "canonical_builder_command": "docker compose --profile builder run --rm --build builder"
}
