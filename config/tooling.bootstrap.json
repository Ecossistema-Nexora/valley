{
  "version": "v47",
  "editor_clis": [
    "code",
    "antigravity"
  ],
  "workspace_extensions": [
    "Dart-Code.dart-code",
    "Dart-Code.flutter",
    "GitHub.vscode-pull-request-github",
    "figma.figma-vscode-extension",
    "github.vscode-github-actions",
    "Google.geminicodeassist",
    "ms-ossdata.vscode-pgsql",
    "ms-python.python",
    "ms-python.vscode-pylance",
    "ms-vscode.powershell",
    "ms-azuretools.vscode-docker",
    "ms-kubernetes-tools.vscode-kubernetes-tools",
    "mongodb.mongodb-vscode",
    "redhat.java",
    "redhat.vscode-yaml",
    "esbenp.prettier-vscode",
    "dbaeumer.vscode-eslint",
    "ms-vscode-remote.remote-containers"
  ],
  "workspace_unwanted_extensions": [
    "oracle.oracle-java",
    "vscjava.vscode-gradle"
  ],
  "host_tools": [
    {
      "name": "code",
      "type": "command",
      "required": true
    },
    {
      "name": "python",
      "type": "command",
      "required": true
    },
    {
      "name": "node",
      "type": "command",
      "required": true
    },
    {
      "name": "docker",
      "type": "command",
      "required": true
    },
    {
      "name": "antigravity",
      "type": "command",
      "required": false
    },
    {
      "name": "git",
      "type": "command",
      "required": true
    },
    {
      "name": "MongoDB Shell",
      "type": "winget",
      "id": "MongoDB.Shell",
      "required": false
    },
    {
      "name": "PostgreSQL 16",
      "type": "winget",
      "id": "PostgreSQL.PostgreSQL.16",
      "required": false
    }
  ],
  "canonical_builder_command": "powershell -ExecutionPolicy Bypass -File scripts/run_valley_compose_builder.ps1",
  "github_repository_binding": {
    "provider": "github",
    "owner": "Ecossistema-Nexora",
    "repo": "valley",
    "url": "https://github.com/Ecossistema-Nexora/valley",
    "fetch_url": "https://github.com/Ecossistema-Nexora/valley.git",
    "push_url": "https://github.com/Ecossistema-Nexora/valley.git",
    "remote_name": "origin",
    "scope_policy": "single_repository_only"
  }
}
