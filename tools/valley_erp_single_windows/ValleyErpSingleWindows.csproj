<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Valley-ERP</AssemblyName>
    <RootNamespace>Valley.Erp.SingleWindows</RootNamespace>
    <Version>1.0.0</Version>
    <Description>Valley ERP Lojista single-file launcher</Description>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="payload.zip" LogicalName="valley-erp-payload.zip" Condition="Exists('payload.zip')" />
  </ItemGroup>
</Project>
