# Template de segredos do ambiente Valley (Codex Cloud)
# Objetivo: centralizar variáveis sensíveis consumidas por scripts de runtime,
# integrações web e automações operacionais do projeto Valley.
# Integração: este arquivo é lido por processos locais via `source` e por tarefas
# de deploy/CI que injetam segredos em tempo de execução.
# Justificativa: manter um template documentado reduz erros de configuração,
# custo operacional e retrabalho entre ambientes (dev/hml/prod).

# Identificação do ambiente
VALLEY_ENV=development
VALLEY_REGION=us-east-1

# Banco de dados
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_POOL_SIZE=10

# Serviços de autenticação
JWT_SECRET=<ALTERAR_COM_UM_SEGREDO_FORTE>
JWT_EXPIRES_IN=3600

# Serviços externos
OPENAI_API_KEY=<INSERIR_CHAVE_AQUI>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=<INSERIR_SENHA_AQUI>

# Observabilidade
SENTRY_DSN=<INSERIR_DSN_AQUI>
LOG_LEVEL=info
