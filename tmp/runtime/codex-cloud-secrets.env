# codex-cloud-secrets.env
# -----------------------------------------------------------------------------
# Arquivo de referência para variáveis de ambiente e segredos usados no ambiente
# "valley" do Codex Cloud.
#
# Objetivo:
# - Centralizar os nomes das variáveis sensíveis exigidas pelo runtime local e
#   pelo ambiente remoto (Ambientes > valley).
# - Reduzir erros de configuração manual e facilitar auditoria de custo/segurança.
#
# Integrações principais:
# - API de produtos (valley-product-api)
# - Banco de dados PostgreSQL
# - Cache Redis
# - Serviços de autenticação/JWT
# - Provedores externos (pagamentos, notificações e observabilidade)
#
# Observação importante:
# - Este arquivo está versionado como template operacional e NÃO deve conter
#   segredo real. Preencha os valores reais apenas no painel seguro do Codex Cloud
#   e/ou em um cofre de segredos.
# - Sempre que adicionar uma nova variável, inclua também justificativa de custo,
#   integração impactada e responsável pela validação.
# -----------------------------------------------------------------------------

# Identificação do ambiente
# Justificativa: identifica o contexto do runtime para evitar deploy em ambiente errado
# e integra com logs/monitoramento regionais.
# Integração: roteamento de infraestrutura, tracing e segmentação de dashboards.
APP_ENV=valley
APP_NAME=valley-platform
APP_REGION=us-east-1

# Banco de dados PostgreSQL
# Justificativa: conexão principal para persistência transacional da plataforma.
# Integração: usado pelos serviços de API e workers de processamento.
# Custo: pool correto evita excesso de conexões ociosas e contenção de CPU no banco.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DB_POOL_MIN=2
DB_POOL_MAX=20

# Cache e fila (Redis)
# Justificativa: melhora performance, rate limit, sessão e filas leves.
# Integração: consumido por API gateway, tarefas assíncronas e sessões distribuídas.
# Custo: reduz consultas repetidas ao banco e latência de endpoints críticos.
REDIS_URL=redis://:PASSWORD@HOST:6379/0

# Segurança e autenticação
# Justificativa: assinatura de tokens JWT e criptografia de dados sensíveis.
# Integração: aplicado em middleware de autenticação, emissão de token e proteção de dados.
# Custo: previne incidentes de segurança que geram retrabalho e indisponibilidade.
JWT_SECRET=REPLACE_WITH_SECURE_VALUE
JWT_EXPIRES_IN=3600
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_KEY

# APIs internas/externas
# Justificativa: integração entre serviços e provedores terceiros.
# Integração: produto, pagamentos e notificações para jornadas de compra e alertas.
# Custo: endpoints e chaves corretos evitam chamadas inválidas cobradas por terceiros.
PRODUCT_API_BASE_URL=https://api.example.com
PAYMENTS_API_KEY=REPLACE_WITH_SECURE_VALUE
NOTIFICATION_WEBHOOK_URL=https://hooks.example.com/endpoint

# Observabilidade
# Justificativa: rastreamento de erros e telemetria para estabilidade e custo.
# Integração: coleta de erro/apm e padronização de nível de logs.
# Custo: LOG_LEVEL ajustado evita excesso de armazenamento e ruído operacional.
SENTRY_DSN=REPLACE_WITH_SECURE_VALUE
LOG_LEVEL=info

# Feature flags e execução
# Justificativa: liberar funcionalidades de forma controlada por ambiente.
# Integração: controle de rollout e proteção de performance em produção.
# Custo: desabilitar recursos não usados reduz consumo de CPU/memória e chamadas externas.
FEATURE_FLAG_NEW_CHECKOUT=false
RUNTIME_TIMEOUT_MS=30000
